rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in [
          'sbrunessalas@gmail.com',
          'marc.brunes95@gmail.com',
          'lauranavarreteclos@gmail.com',
          'xamolo@hotmail.com',
          'cristina.naqui@gmail.com',
          'ari.veny.reast@gmail.com'
        ];
    }

    match /grups/{grupId} {
      // Només membres poden llegir el seu grup
      allow read: if request.auth != null
        && request.auth.token.email in resource.data.membresCorreus;

      // Qualsevol usuari autenticat pot crear (ell ha d'estar a membresCorreus)
      allow create: if request.auth != null
        && request.auth.token.email in request.resource.data.membresCorreus;

      // Membres poden editar (afegir nous membres, etc.)
      allow update: if request.auth != null
        && request.auth.token.email in resource.data.membresCorreus;

      // Només el titular pot eliminar
      allow delete: if request.auth != null
        && request.auth.token.email == resource.data.titular;
    }

    match /usuaris/{userId} {
      // Cada usuari llegeix i escriu només el seu perfil
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
